fundamental-mode

(box "┌─" (make-string (length str) ?─) "─┐" n
     "│ " (p "one line text" str)       " │" n
     "└─" (make-string (length str) ?─) "─┘" n)
(calc (p "taylor(sin(x),x=0,3)" formula) n "----" n (format "%s" (calc-eval formula)))

org-mode
(e "#+begin_src emacs-lisp" n r n "#+end_src" :post (org-edit-src-code))
(s "#+begin_src" n r n "#+end_src")
(t (format-time-string "TODO [%Y-%m-%d %a]: ") q (format-time-string " <%Y-%m-%d %a>") :post (progn (org-toggle-heading) (org-metaleft)))
(ts (format-time-string "TODO [%Y-%m-%d %a]: ") q (format-time-string " <%Y-%m-%d %a>") :post (org-toggle-heading))
(c (format-time-string "=com [%Y-%m-%d %a] --") q "=")
(cb "- [ ] " r)

python-mode
(a "assert 0 == 1" r)
(pp "import pprint; pprint.pprint(" r ")")
(li "logger.info(" r ")")
(lif "logger.info(f'{" r "=}')")
(ai "#AI: ")

eshell-mode
(de "setxkbmap de" r)

eca-chat-mode
(d "maintain docstring using the python-doc-manager skill for file `" r"`")
(r "review last commit")
(t "closely follow auto-tdd. create only one test and then do a minimal implementation")
(nc "use list-all-shortcomings and recommend the next shortcoming to solve")
(nm "this is not a minimal implementation")
(ot "only one test per tdd-cycle")
(nc "now code changes without creating a failing test first")
(chl "update changelog based on the commit in this branch. make sure to also run the bash command `date` to get the date of today")
(mfs "maintain features and shortcomings in the aspect-folder")
(uss "use the bash command `shortcomings` to add features. i manually installed it")

